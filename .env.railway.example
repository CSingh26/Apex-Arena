# SPDX-License-Identifier: AGPL-3.0-only
#
# Apex Arena — Railway backend service variables.
#
# PLACEHOLDERS ONLY. Never commit real values. Set anything marked (secret) as
# a Railway secret variable, not a plain variable.
#
# Source branch: main.
# Choose ONE role:
#   * APP_PROCESS_ROLE=combined — one service that serves the API and runs
#     recent-session REST reconciliation behind a singleton advisory lease.
#   * APP_PROCESS_ROLE=api / APP_PROCESS_ROLE=ingestor — split mode for later scaling.

# ─── Runtime ────────────────────────────────────────────────────────────────
APP_ENV=production
# api | ingestor | combined
APP_PROCESS_ROLE=combined
APP_NAME="Apex Arena"
# PORT is injected by Railway; app/runtime.py honours it. Do not hardcode it.
LOG_LEVEL=info
LOG_FORMAT=json

# ─── Public identity (browser-visible values only) ──────────────────────────
APP_BASE_PATH=/apex-arena
PUBLIC_BASE_URL=https://chaitanyasingh.org/apex-arena
PRODUCTION_FRONTEND_URL=https://chaitanyasingh.org/apex-arena
PRODUCTION_BACKEND_URL=https://chaitanyasingh.org/apex-arena/api
CORS_ALLOWED_ORIGINS=https://chaitanyasingh.org

# ─── Proxy trust ────────────────────────────────────────────────────────────
# Must equal APEX_ARENA_BACKEND_PROXY_TOKEN on the Apex Arena Vercel project.
APEX_ARENA_PROXY_TOKEN=replace-with-a-long-random-value   # (secret)
PUBLIC_PROXY_HOST=chaitanyasingh.org
TRUSTED_PROXY_HOSTS=chaitanyasingh.org
PROXY_ENFORCEMENT_ENABLED=true

# ─── Neon PostgreSQL ────────────────────────────────────────────────────────
# Runtime uses the POOLED endpoint. Use ssl=require (not sslmode/channel_binding);
# a pasted Neon libpq string is normalized automatically, but ssl=require is clearest.
DATABASE_URL=postgresql://USER:PASSWORD@ep-example-pooler.REGION.aws.neon.tech/apex_arena?ssl=require   # (secret)
# DIRECT endpoint. Required for Alembic and for the ingestor's session-scoped
# advisory lease, both of which a transaction pooler silently breaks.
DATABASE_MIGRATION_URL=postgresql://USER:PASSWORD@ep-example.REGION.aws.neon.tech/apex_arena?ssl=require   # (secret)
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT_SECONDS=15
DB_POOL_RECYCLE_SECONDS=300

# ─── Upstash Redis ──────────────────────────────────────────────────────────
# Must be rediss:// — the application rejects plaintext Redis in production.
REDIS_URL=rediss://default:PASSWORD@example-12345.upstash.io:6379   # (secret)
REDIS_SOCKET_TIMEOUT_SECONDS=5
REDIS_CONNECT_TIMEOUT_SECONDS=5
REDIS_HEALTH_CHECK_INTERVAL_SECONDS=30

# ─── OpenF1 (ingestor / combined roles only) ────────────────────────────────
OPENF1_REST_BASE_URL=https://api.openf1.org/v1
OPENF1_AUTH_URL=https://api.openf1.org/token
OPENF1_MQTT_HOST=mqtt.openf1.org
OPENF1_MQTT_PORT=8883
OPENF1_MQTT_WS_URL=wss://mqtt.openf1.org:8084/mqtt
OPENF1_USERNAME=replace-with-openf1-username     # (secret)
OPENF1_PASSWORD=replace-with-openf1-password     # (secret)
# true on the ingestor/combined service, false on the API service.
# Production rejects APP_PROCESS_ROLE=api together with auto-connect.
OPENF1_LIVE_AUTO_CONNECT=false
OPENF1_INGESTION_MODE=rest
OPENF1_REST_BACKFILL_ENABLED=false
OPENF1_REST_INCLUDE_HIGH_FREQUENCY=false
RECENT_SESSION_RECONCILIATION_ENABLED=true
RECENT_SESSION_AUTO_BACKFILL_ENABLED=true
RECENT_SESSION_RECONCILIATION_LOOKBACK_DAYS=14
RECENT_SESSION_PROVIDER_GRACE_MINUTES=15
RECENT_SESSION_RECONCILIATION_INTERVAL_SECONDS=900
RECENT_SESSION_AUTO_BACKFILL_MAX_SESSIONS=1
RECENT_SESSION_AUTO_BACKFILL_MAX_CONCURRENT=1

# ─── AI (funded separately) ─────────────────────────────────────────────────
OPENAI_API_KEY=replace-with-openai-key   # (secret)
AI_ENABLED=true
AI_KILL_SWITCH=false

# ─── Privileged operations ──────────────────────────────────────────────────
INTERNAL_API_KEY=replace-with-a-long-random-value   # (secret)

# ─── Production safety (validated at startup) ───────────────────────────────
DEBUG_INGESTION_ENABLED=false
DEVELOPMENT_FIXTURE_ENABLED=false
ROOM_DIAGNOSTICS_ENABLED=false

# ─── Telemetry retention (opt-in; 0 disables pruning) ───────────────────────
RAW_EVENT_RETENTION_DAYS=0
NORMALIZED_EVENT_RETENTION_DAYS=0
PROVIDER_PAYLOAD_RETENTION_DAYS=0
REPLAY_ARCHIVE_ENABLED=false

# ─── Observability (optional) ───────────────────────────────────────────────
SENTRY_DSN=
