# SPDX-License-Identifier: AGPL-3.0-only
# Copy this file to .env and replace every change-me value before local use.

APP_NAME="Apex Arena"
APP_ENV=local
NODE_ENV=development

SEASON_YEAR=2026
SEASON_ONLY_MODE=true
TARGET_GRAND_PRIX="Belgian Grand Prix"
TARGET_CIRCUIT="Spa-Francorchamps"

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
FRONTEND_PORT=3000
BACKEND_PORT=8000

NEXT_PUBLIC_APP_NAME="Apex Arena"
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

DATABASE_URL=postgresql://apex:change-me@localhost:5432/apex_arena
POSTGRES_DB=apex_arena
POSTGRES_USER=apex
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
# Override both this port and DATABASE_URL together when 5432 is occupied.
POSTGRES_PORT=5432

REDIS_URL=redis://localhost:6379/0
# Override both this port and REDIS_URL together when 6379 is occupied.
REDIS_PORT=6379

OPENF1_REST_BASE_URL=https://api.openf1.org/v1
OPENF1_USERNAME=
OPENF1_PASSWORD=
OPENF1_AUTH_URL=https://api.openf1.org/token
OPENF1_MQTT_HOST=mqtt.openf1.org
OPENF1_MQTT_PORT=8883
OPENF1_MQTT_WS_URL=wss://mqtt.openf1.org:8084/mqtt
OPENF1_TOKEN_REFRESH_BUFFER_SECONDS=300
OPENF1_RECONNECT_MAX_ATTEMPTS=20
OPENF1_RECONNECT_BASE_DELAY_MS=1000
OPENF1_RECONNECT_MAX_DELAY_MS=30000
OPENF1_LIVE_AUTO_CONNECT=false
OPENF1_LIVE_TOPICS=v1/sessions,v1/drivers,v1/position,v1/intervals,v1/laps,v1/pit,v1/stints,v1/race_control,v1/weather

JOLPICA_BASE_URL=https://api.jolpi.ca/ergast/f1

OPENAI_API_KEY=
AI_ENABLED=true
OPENAI_REACTION_MODEL=gpt-4.1-mini
OPENAI_SUMMARY_MODEL=gpt-4.1-mini
AI_MAX_CALLS_PER_MINUTE=20
AI_MAX_CALLS_PER_SESSION=500
AI_MAX_AGENTS_PER_EVENT=4
AI_REQUEST_TIMEOUT_MS=20000
AI_DAILY_TOKEN_BUDGET=1000000
AI_KILL_SWITCH=false

LIVE_MODE_ENABLED=true
LIVE_STALE_AFTER_SECONDS=15
LIVE_DEGRADED_AFTER_SECONDS=45
EVENT_DEDUP_TTL_SECONDS=3600
EVENT_ORDERING_BUFFER_MS=1500
EVENT_IMPORTANCE_MIN_FOR_AI=0.55
REACTION_QUEUE_ENABLED=true
REACTION_QUEUE_MAX_SIZE=100
REACTION_STALE_AFTER_SECONDS=30

STREAM_BACKEND=sse
SSE_HEARTBEAT_SECONDS=15
RACE_STATE_SNAPSHOT_EVERY_N_EVENTS=10
ENGINE_RECENT_EVENTS_LIMIT=100
HISTORICAL_INGESTION_ENABLED=true
HISTORICAL_INGESTION_MAX_RECORDS_PER_ENDPOINT=5000
DEBUG_INGESTION_ENABLED=true

ENABLE_LIVE_ROOMS=true
ENABLE_HISTORICAL_REPLAY=true
ENABLE_AUTO_ROOM_CREATION=true
ENABLE_AGENT_MEMORY=true
ENABLE_AGENT_PREDICTIONS=true
ENABLE_PUBLIC_REPLAYS=true
ENABLE_USER_CHAT=false
ENABLE_USER_CREATED_AGENTS=false
ENABLE_VECTOR_MEMORY=false
ENABLE_MONTE_CARLO=false

JWT_SECRET=
SESSION_SECRET=
INTERNAL_API_KEY=
ADMIN_DASHBOARD_PASSWORD=
CORS_ALLOWED_ORIGINS=http://localhost:3000

LOG_LEVEL=info
LOG_FORMAT=pretty

SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

PRODUCTION_FRONTEND_URL=https://apex.chaitanyasingh.org
PRODUCTION_BACKEND_URL=https://api.apex.chaitanyasingh.org
PUBLIC_BASE_URL=https://apex.chaitanyasingh.org
