# SPDX-License-Identifier: AGPL-3.0-only
#
# Apex Arena — Vercel frontend project variables (Vercel project 2).
#
# PLACEHOLDERS ONLY. Never commit real values.
#
# This project is an ORIGIN, not the public site. The public domain
# (chaitanyasingh.org) stays on the portfolio project, which rewrites
# /apex-arena/* here. Do not attach the public domain to this project.
#
# Vercel environment variable changes only take effect on a NEW deployment.

# ─── Public (inlined into the browser bundle — never put a secret here) ─────
NEXT_PUBLIC_APP_NAME="Apex Arena"
# Single source of truth for the mount point. Next.js basePath is derived from it.
NEXT_PUBLIC_APP_BASE_PATH=/apex-arena
# Browser-facing API prefix. Defaults to "<base path>/api" when unset.
NEXT_PUBLIC_API_BASE_PATH=/apex-arena/api
# Public origin used for canonical tags, Open Graph metadata and share links.
NEXT_PUBLIC_APP_URL=https://chaitanyasingh.org/apex-arena
NEXT_PUBLIC_SENTRY_DSN=

# ─── Server-side only (never prefix any of these with NEXT_PUBLIC_) ─────────
# Public identity used by server components.
PUBLIC_APP_URL=https://chaitanyasingh.org/apex-arena

# FastAPI origin on Railway. The route handler at /api/[[...path]] proxies to
# it server-side, so the backend host never reaches the browser.
BACKEND_PUBLIC_ORIGIN=https://apex-arena-api-REPLACE.up.railway.app
# Preferred when the frontend and backend share a private network. Takes
# precedence over BACKEND_PUBLIC_ORIGIN when set.
# BACKEND_INTERNAL_URL=http://backend.railway.internal:8000

# Sent as X-Apex-Proxy-Token to the backend. MUST equal APEX_ARENA_PROXY_TOKEN
# on the Railway service, or the backend answers 403 to every request.
APEX_ARENA_BACKEND_PROXY_TOKEN=replace-with-a-long-random-value

# In production the route handler returns 503 rather than falling back to
# localhost, so one of the backend origin variables above is mandatory.
